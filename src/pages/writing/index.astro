---
import Base from '../../layouts/Base.astro';
import SectionHead from '../../components/SectionHead.astro';
import Row from '../../components/Row.astro';
import { getCollection } from 'astro:content';
import { fmtDate } from '../../lib/feed';

const all = (await getCollection('writing', e => !e.data.draft))
  .sort((a, b) => +b.data.date - +a.data.date);

const byYear = new Map<number, typeof all>();
for (const e of all) {
  const y = e.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(e);
}
const years = [...byYear.entries()].sort((a, b) => b[0] - a[0]);
---
<Base
  title="Writing — ctrl-alt-adrian"
  description="Essays and shorter notes, newest first."
  current="writing"
>
  <header class="page">
    <div class="crumb"><a href="/">← Home</a></div>
    <h1>Writing</h1>
    <p>
      Essays and shorter notes, newest first. {all.length} pieces.
    </p>
  </header>

  {years.map(([year, posts]) => (
    <section>
      <div class="yearhead">
        <h2>{year}</h2>
        <span class="count">{posts.length} {posts.length === 1 ? 'piece' : 'pieces'}</span>
      </div>
      <ul class="rows">
        {posts.map(e => (
          <Row
            date={fmtDate(e.data.date)}
            kind={e.data.kind}
            title={e.data.title}
            href={`/writing/${e.slug}`}
            tags={e.data.tags}
          />
        ))}
      </ul>
    </section>
  ))}
</Base>

<style>
  .page { margin: 48px 0 56px; }
  .page .crumb { font-size: 12.5px; color: var(--muted); margin-bottom: 6px; }
  .page .crumb a { color: var(--muted); text-decoration: none; }
  .page .crumb a:hover { color: var(--fg); }
  .page h1 { margin: 0; font-size: 17px; font-weight: 600; letter-spacing: -0.005em; }
  .page p { margin: 4px 0 0; color: var(--muted); max-width: 520px; text-wrap: pretty; }
  .yearhead {
    display: flex; align-items: baseline; justify-content: space-between;
    margin-bottom: 14px; border-bottom: 1px solid var(--rule); padding-bottom: 10px;
  }
  .yearhead h2 {
    margin: 0; font-size: 12px; font-weight: 600; color: var(--muted);
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  .yearhead .count { color: var(--muted); font-size: 12.5px; }
  section { margin-bottom: 44px; }
  .rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 86px 96px max-content 1fr;
    row-gap: 6px;
  }
  @media (max-width: 720px) {
    .rows { grid-template-columns: auto auto 1fr; }
  }
</style>
