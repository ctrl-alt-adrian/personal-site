---
import Base from '../../layouts/Base.astro';
import Row from '../../components/Row.astro';
import { getCollection } from 'astro:content';
import { fmtDate } from '../../lib/feed';

const log = (await getCollection('log', e => !e.data.draft))
  .sort((a, b) => +b.data.date - +a.data.date);
---
<Base
  title="Build log — ctrl-alt-adrian"
  description="Build-in-public, in chronological order."
>
  <header class="page">
    <div class="crumb"><a href="/">← Home</a></div>
    <h1>Build log</h1>
    <p>What I'm shipping, in chronological order. {log.length} entries.</p>
  </header>

  <ul class="rows">
    {log.map(e => (
      <Row
        date={fmtDate(e.data.date)}
        kind="build"
        title={e.data.title}
        href={`/log/${e.slug}`}
        meta={e.data.project ? `· ${e.data.project}` : undefined}
      />
    ))}
  </ul>
</Base>

<style>
  .page { margin: 48px 0 36px; }
  .page .crumb { font-size: 12.5px; color: var(--muted); margin-bottom: 6px; }
  .page .crumb a { color: var(--muted); text-decoration: none; }
  .page h1 { margin: 0; font-size: 17px; font-weight: 600; letter-spacing: -0.005em; }
  .page p  { margin: 4px 0 0; color: var(--muted); max-width: 520px; text-wrap: pretty; }
  .rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 86px 96px max-content 1fr auto;
    row-gap: 6px;
  }
  @media (max-width: 720px) {
    .rows { grid-template-columns: auto auto 1fr; }
  }
</style>
