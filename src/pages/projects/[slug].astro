---
import Base from '../../layouts/Base.astro';
import Row from '../../components/Row.astro';
import { getCollection } from 'astro:content';
import { fmtDate } from '../../lib/feed';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({ params: { slug: p.id.replace(/\.json$/, '') }, props: { project: p } }));
}

const { project } = Astro.props;
const slug = project.id.replace(/\.json$/, '');

const related = (await getCollection('writing', e => !e.data.draft && e.data.project === slug))
  .sort((a, b) => +b.data.date - +a.data.date);
---
<Base
  title={`${project.data.name} — ctrl-alt-adrian`}
  description={project.data.desc}
>
  <article>
    <div class="crumb"><a href="/#projects">← Projects</a></div>

    <header class="meta">
      <span class="status">{project.data.status}</span>
      <span class="dot" aria-hidden="true">·</span>
      <span class="tag">{project.data.tag}</span>
      {project.data.shipped && (
        <>
          <span class="dot" aria-hidden="true">·</span>
          <time datetime={project.data.shipped.toISOString()}>{fmtDate(project.data.shipped)}</time>
        </>
      )}
    </header>

    <h1>{project.data.name}</h1>
    <p class="desc">{project.data.desc}</p>

    {project.data.url && (
      <p class="link">
        <a href={project.data.url} target="_blank" rel="noopener noreferrer">{project.data.url.replace(/^https?:\/\//, '')} ↗</a>
      </p>
    )}

    {related.length > 0 && (
      <section>
        <h2>Writing</h2>
        <ul class="rows">
          {related.map(e => (
            <Row
              date={fmtDate(e.data.date)}
              kind={e.data.kind}
              title={e.data.title}
              href={`/writing/${e.slug}`}
              tags={e.data.tags}
            />
          ))}
        </ul>
      </section>
    )}
  </article>
</Base>

<style>
  article { margin: 48px 0 72px; }
  .crumb { font-size: 12.5px; color: var(--muted); margin-bottom: 20px; }
  .crumb a { color: var(--muted); text-decoration: none; }
  .crumb a:hover { color: var(--fg); }
  .meta {
    display: flex; gap: 8px; align-items: baseline;
    color: var(--muted); font-size: 13.5px; margin-bottom: 4px;
  }
  .meta .status { color: var(--muted); }
  .meta .tag { color: var(--accent); }
  .meta .dot { color: var(--rule); }
  h1 {
    margin: 0 0 12px; font-size: 28px; font-weight: 600;
    letter-spacing: -0.02em; line-height: 1.2; text-wrap: balance;
  }
  .desc { margin: 0 0 12px; color: var(--fg); max-width: 64ch; line-height: 1.6; }
  .link { margin: 0 0 40px; font-size: 14px; }
  .link a {
    color: var(--fg);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .link a:hover { text-decoration-color: currentColor; }
  section h2 {
    margin: 0 0 14px;
    font-size: 12px; font-weight: 600; color: var(--muted);
    letter-spacing: 0.14em; text-transform: uppercase;
    border-bottom: 1px solid var(--rule); padding-bottom: 10px;
  }
  .rows {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 86px 96px max-content 1fr;
    row-gap: 6px;
  }
  @media (max-width: 720px) {
    .rows { grid-template-columns: auto auto 1fr; }
  }
</style>
