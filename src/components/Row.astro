---
interface Props {
  date: string;
  kind: string;
  title: string;
  href: string;
  meta?: string;
  dim?: boolean;
  tags?: string[];
  more?: { href: string; text?: string };
}
const { date, kind, title, href, meta, dim, tags, more } = Astro.props;
const isExternal = /^https?:\/\//.test(href);
---
<li class:list={["row", { dim }]}>
  <span class="date">{date}</span>
  <span class="kind">{kind}</span>
  <a
    class="title"
    href={href}
    {...isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
  >{title}</a>
  <span class="meta">
    {meta ?? ''}
    {more && (
      <> <a class="more" href={more.href}>{more.text ?? 'see more'} →</a></>
    )}
  </span>
  {tags && tags.length > 0 && (
    <ul class="tags">
      {tags.map(t => <li>#{t}</li>)}
    </ul>
  )}
</li>

<style>
  .row {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: subgrid;
    column-gap: 16px;
    align-items: baseline;
    font-size: 15.5px;
    line-height: 1.7;
    transition: opacity 180ms ease;
  }
  .date {
    color: var(--muted);
    font-size: 14px;
    font-variant-numeric: tabular-nums;
  }
  .kind {
    color: var(--accent);
    font-size: 13px;
  }
  .title {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    white-space: nowrap;
  }
  .title:hover { border-bottom-color: currentColor; }
  .meta {
    color: var(--muted);
    font-size: 14.5px;
    min-width: 0;
    padding-left: 1.4em;
    text-indent: -1.4em;
  }
  .meta .more {
    color: var(--muted);
    text-decoration: underline;
    text-decoration-color: var(--rule);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    white-space: nowrap;
  }
  .meta .more:hover { color: var(--fg); text-decoration-color: currentColor; }
  .tags {
    grid-column: 3 / -1;
    list-style: none; padding: 0; margin: 2px 0 0;
    display: flex; flex-wrap: wrap; gap: 4px 10px;
    font-size: 12.5px; color: var(--muted);
    font-family: ui-monospace, 'JetBrains Mono', monospace;
  }
  .row.dim { opacity: 0.45; }
  .row.dim:hover { opacity: 1; }
  @media (max-width: 720px) {
    .row {
      grid-template-columns: auto auto 1fr;
      column-gap: 10px;
      row-gap: 4px;
    }
    .title { grid-column: 1 / -1; white-space: normal; }
    .meta { grid-column: 1 / -1; }
    .tags { grid-column: 1 / -1; }
  }
</style>
